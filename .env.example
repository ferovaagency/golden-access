# Ferova OS necesita estas variables PÚBLICAS para inicializar el cliente de Supabase.
# Lovable Cloud debe inyectarlas en sus despliegues conectados. Estas líneas sirven
# únicamente para desarrollo local o para un entorno de compilación externo.
# La clave publishable es apta para el navegador; la protección de datos depende de RLS.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<tu-clave-publica>

# PayPal Client ID (cliente, público). No incluir el Secret ni el Webhook ID en VITE_.
# VITE_PAYPAL_CLIENT_ID=xxx

# Configurar solo como secretos de Supabase Edge Functions, nunca en este archivo:
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
