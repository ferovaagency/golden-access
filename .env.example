# Ferova OS usa Lovable Cloud + Lovable AI Gateway.
# Las claves reales se gestionan automáticamente por Lovable en el entorno hospedado.
# Este archivo solo existe como referencia — no se requiere para el desarrollo local básico.

# Paddle live (cliente). No incluir secretos de API ni de webhooks en VITE_.
# VITE_PADDLE_CLIENT_TOKEN=live_xxx
# VITE_PADDLE_DEFAULT_PRICE_ID=pri_xxx

# Configurar solo como secretos de Supabase Edge Functions, nunca en este archivo:
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
